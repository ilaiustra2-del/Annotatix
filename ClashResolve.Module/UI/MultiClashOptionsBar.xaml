<UserControl x:Class="ClashResolve.Module.UI.MultiClashOptionsBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI"
             FontSize="12"
             Background="#4C4C4C"
             VerticalAlignment="Stretch">

    <!-- Shared ComboBox item style resource -->
    <UserControl.Resources>
        <Style x:Key="DarkComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="#3C3C3C" Padding="6,3">
                            <TextBlock x:Name="Txt"
                                       Text="{TemplateBinding ContentControl.Content}"
                                       Foreground="#FFFFFF"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>

        <!-- ══════════════════════════════════════════════════════════
             STEP 1 — Select pipes A (pipes to be rerouted)
             ══════════════════════════════════════════════════════════ -->
        <StackPanel x:Name="panelStep1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">

            <TextBlock Text="Множественное исправление коллизий"
                       FontWeight="SemiBold"
                       Foreground="#E8E8E8"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

            <TextBlock Text="Выберите трубы, трассировка которых будет изменена"
                       Foreground="#CCCCCC"
                       VerticalAlignment="Center"
                       Margin="4,0,8,0"/>

            <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

            <TextBlock x:Name="txtCount1"
                       Text="Выбрано: 0"
                       Foreground="#AAAAAA"
                       FontStyle="Italic"
                       VerticalAlignment="Center"
                       Margin="4,0,8,0"/>

            <Button x:Name="btnDone1"
                    Content="Готово"
                    Foreground="#E8E8E8"
                    Background="#3A5A3A"
                    BorderBrush="#888888"
                    Padding="10,2"
                    VerticalAlignment="Center"
                    Margin="0,0,4,0"
                    Click="BtnDone1_Click"/>

            <Button x:Name="btnCancel1"
                    Content="Отмена"
                    Foreground="#E8E8E8"
                    Background="#5A3A3A"
                    BorderBrush="#888888"
                    Padding="10,2"
                    VerticalAlignment="Center"
                    Click="BtnCancel_Click"/>

        </StackPanel>

        <!-- ══════════════════════════════════════════════════════════
             STEP 2 — Select pipes B (static obstacles)
             ══════════════════════════════════════════════════════════ -->
        <StackPanel x:Name="panelStep2" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0"
                    Visibility="Collapsed">

            <TextBlock Text="Множественное исправление коллизий"
                       FontWeight="SemiBold"
                       Foreground="#E8E8E8"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

            <TextBlock Text="Выберите трубы, положение которых остается неизменным"
                       Foreground="#CCCCCC"
                       VerticalAlignment="Center"
                       Margin="4,0,8,0"/>

            <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

            <TextBlock x:Name="txtCount2"
                       Text="Выбрано: 0"
                       Foreground="#AAAAAA"
                       FontStyle="Italic"
                       VerticalAlignment="Center"
                       Margin="4,0,8,0"/>

            <Button x:Name="btnDone2"
                    Content="Готово"
                    Foreground="#E8E8E8"
                    Background="#3A5A3A"
                    BorderBrush="#888888"
                    Padding="10,2"
                    VerticalAlignment="Center"
                    Margin="0,0,4,0"
                    Click="BtnDone2_Click"/>

            <Button x:Name="btnCancel2"
                    Content="Отмена"
                    Foreground="#E8E8E8"
                    Background="#5A3A3A"
                    BorderBrush="#888888"
                    Padding="10,2"
                    VerticalAlignment="Center"
                    Click="BtnCancel_Click"/>

        </StackPanel>

        <!-- ══════════════════════════════════════════════════════════
             STEP 3 — Configure parameters and execute
             ══════════════════════════════════════════════════════════ -->
        <StackPanel x:Name="panelStep3" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0"
                    Visibility="Collapsed">

            <TextBlock Text="Множественное исправление коллизий"
                       FontWeight="SemiBold"
                       Foreground="#E8E8E8"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

            <!-- Angle -->
            <TextBlock Text="Угол обхода:"
                       Foreground="#CCCCCC"
                       VerticalAlignment="Center"
                       Margin="4,0,4,0"/>
            <ComboBox x:Name="cmbAngle"
                      Width="60"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      SelectionChanged="CmbAngle_SelectionChanged">
                <ComboBox.Template>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="TgBd"
                                                Background="#3C3C3C"
                                                BorderBrush="#555555"
                                                BorderThickness="1"
                                                CornerRadius="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="16"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="4,2,0,2"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="#FFFFFF"
                                                                  VerticalAlignment="Center"
                                                                  IsHitTestVisible="False"/>
                                                <Path Grid.Column="1"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#AAAAAA"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TgBd" Property="Background" Value="#505050"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="TgBd" Property="Background" Value="#505050"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropBd"
                                        Background="#3C3C3C"
                                        BorderBrush="#555555"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </ComboBox.Template>
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource DarkComboItemStyle}"/>
                </ComboBox.ItemContainerStyle>
                <ComboBoxItem Content="90°" IsSelected="True"/>
                <ComboBoxItem Content="60°"/>
                <ComboBoxItem Content="45°"/>
                <ComboBoxItem Content="30°"/>
            </ComboBox>

            <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

            <!-- Bypass direction -->
            <TextBlock Text="Направление:"
                       Foreground="#CCCCCC"
                       VerticalAlignment="Center"
                       Margin="4,0,4,0"/>
            <ComboBox x:Name="cmbDirection"
                      Width="70"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0">
                <ComboBox.Template>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="TgBd"
                                                Background="#3C3C3C"
                                                BorderBrush="#555555"
                                                BorderThickness="1"
                                                CornerRadius="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="16"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="4,2,0,2"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="#FFFFFF"
                                                                  VerticalAlignment="Center"
                                                                  IsHitTestVisible="False"/>
                                                <Path Grid.Column="1"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="#AAAAAA"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TgBd" Property="Background" Value="#505050"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="TgBd" Property="Background" Value="#505050"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropBd"
                                        Background="#3C3C3C"
                                        BorderBrush="#555555"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </ComboBox.Template>
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource DarkComboItemStyle}"/>
                </ComboBox.ItemContainerStyle>
                <ComboBoxItem Content="Снизу" IsSelected="True"/>
                <ComboBoxItem Content="Сверху"/>
            </ComboBox>

            <Rectangle Width="1" Fill="#666666" Margin="4,3"/>
            <TextBlock Text="Величина опуска:"
                       Foreground="#CCCCCC"
                       VerticalAlignment="Center"
                       Margin="4,0,4,0"/>
            <TextBox x:Name="txtClearance"
                     Width="52"
                     Text="50"
                     Background="#3A3A3A"
                     Foreground="#E8E8E8"
                     BorderBrush="#666666"
                     CaretBrush="#E8E8E8"
                     VerticalAlignment="Center"
                     VerticalContentAlignment="Center"
                     Padding="3,1"
                     Margin="0,0,6,0"
                     IsEnabled="False"
                     Opacity="0.5"/>
            <CheckBox x:Name="chkAutoClearance"
                      Content="Авто"
                      IsChecked="True"
                      Foreground="#E8E8E8"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"/>

            <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

            <!-- Segment length -->
            <TextBlock Text="Длина сегмента:"
                       Foreground="#CCCCCC"
                       VerticalAlignment="Center"
                       Margin="4,0,4,0"/>
            <TextBox x:Name="txtSegmentLength"
                     Width="52"
                     Text="600"
                     Background="#3A3A3A"
                     Foreground="#E8E8E8"
                     BorderBrush="#666666"
                     CaretBrush="#E8E8E8"
                     VerticalAlignment="Center"
                     VerticalContentAlignment="Center"
                     Padding="3,1"
                     Margin="0,0,6,0"
                     IsEnabled="False"
                     Opacity="0.5"/>
            <CheckBox x:Name="chkAutoLength"
                      Content="Авто"
                      IsChecked="True"
                      Foreground="#E8E8E8"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"/>

            <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

            <Button x:Name="btnDone3"
                    Content="Готово"
                    Foreground="#E8E8E8"
                    Background="#3A5A3A"
                    BorderBrush="#888888"
                    Padding="10,2"
                    VerticalAlignment="Center"
                    Margin="4,0,4,0"
                    Click="BtnDone3_Click"/>

            <Button x:Name="btnCancel3"
                    Content="Отмена"
                    Foreground="#E8E8E8"
                    Background="#5A3A3A"
                    BorderBrush="#888888"
                    Padding="10,2"
                    VerticalAlignment="Center"
                    Click="BtnCancel_Click"/>

            <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

            <!-- Lookup table button + enable checkbox -->
            <Button x:Name="btnLookupTable"
                    Content="Таблицы параметров"
                    Foreground="#E8E8E8"
                    Background="#3A4A5A"
                    BorderBrush="#557799"
                    Padding="10,2"
                    VerticalAlignment="Center"
                    Margin="0,0,6,0"
                    Click="BtnLookupTable_Click"/>
            <CheckBox x:Name="chkUseTable"
                      Content="Использовать"
                      Foreground="#E8E8E8"
                      VerticalAlignment="Center"
                      ToolTip="Включить использование таблиц параметров вместо авто-расчёта"
                      Checked="ChkUseTable_Changed"
                      Unchecked="ChkUseTable_Changed"/>

        </StackPanel>

    </Grid>
</UserControl>

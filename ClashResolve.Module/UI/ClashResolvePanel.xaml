<UserControl x:Class="ClashResolve.Module.UI.ClashResolvePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI"
             Background="White">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ─── Section 1: Pipe A ─── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,4">
            <TextBlock Text="Труба A — обходящая (опускается)"
                       FontSize="12" Foreground="#333333" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtPipeA"
                         Grid.Column="0"
                         Text="Не выбрана"
                         IsReadOnly="True"
                         Background="#F8F8F8"
                         BorderBrush="#ADADAD"
                         BorderThickness="1"
                         Padding="6"
                         FontSize="12"
                         Foreground="#888888"/>
                <Button x:Name="btnPickA"
                        Grid.Column="1"
                        Content="Выбрать"
                        Style="{StaticResource SecondaryButton}"
                        Margin="8,0,0,0"
                        Padding="12,5"
                        FontSize="12"
                        Click="BtnPickA_Click"/>
            </Grid>
        </StackPanel>

        <!-- ─── Section 2: Pipe B ─── -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Труба B — препятствие (остаётся)"
                       FontSize="12" Foreground="#333333" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtPipeB"
                         Grid.Column="0"
                         Text="Не выбрана"
                         IsReadOnly="True"
                         Background="#F8F8F8"
                         BorderBrush="#ADADAD"
                         BorderThickness="1"
                         Padding="6"
                         FontSize="12"
                         Foreground="#888888"/>
                <Button x:Name="btnPickB"
                        Grid.Column="1"
                        Content="Выбрать"
                        Style="{StaticResource SecondaryButton}"
                        Margin="8,0,0,0"
                        Padding="12,5"
                        FontSize="12"
                        Click="BtnPickB_Click"/>
            </Grid>
        </StackPanel>

        <!-- ─── Section 3: Parameters ─── -->
        <Grid Grid.Row="2" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Clearance -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Отступ под трубой B (мм)"
                           FontSize="12" Foreground="#333333" Margin="0,0,0,4"/>
                <TextBox x:Name="txtClearance"
                         Text="50"
                         Height="26"
                         FontSize="12"
                         BorderBrush="#ADADAD"
                         Padding="6,4"
                         TextAlignment="Center"/>
            </StackPanel>

            <!-- Half-length -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Длина сегмента (мм)"
                           FontSize="12" Foreground="#333333" Margin="0,0,0,4"/>
                <TextBox x:Name="txtHalfLength"
                         Text="600"
                         Height="26"
                         FontSize="12"
                         BorderBrush="#ADADAD"
                         Padding="6,4"
                         TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ─── Auto clearance checkbox ─── -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="chkAutoClearance"
                      Grid.Column="0"
                      Content="Авто подбор отступа"
                      FontSize="12"
                      Foreground="#333333"
                      Checked="ChkAutoClearance_Changed"
                      Unchecked="ChkAutoClearance_Changed"/>
            <CheckBox x:Name="chkAutoHalfLength"
                      Grid.Column="2"
                      Content="Авто подбор полудлины"
                      FontSize="12"
                      Foreground="#333333"
                      Checked="ChkAutoHalfLength_Changed"
                      Unchecked="ChkAutoHalfLength_Changed"/>
        </Grid>

        <!-- ─── Angle selector ─── -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Угол соединения:"
                       FontSize="12" Foreground="#333333"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <RadioButton x:Name="rbAngle90" Content="90°"
                         IsChecked="True"
                         FontSize="12"
                         Margin="0,0,12,0"
                         VerticalAlignment="Center"
                         Checked="RbAngle_Changed"/>
            <RadioButton x:Name="rbAngle60" Content="60°"
                         FontSize="12"
                         Margin="0,0,12,0"
                         VerticalAlignment="Center"
                         Checked="RbAngle_Changed"/>
            <RadioButton x:Name="rbAngle45" Content="45°"
                         FontSize="12"
                         Margin="0,0,12,0"
                         VerticalAlignment="Center"
                         Checked="RbAngle_Changed"/>
            <RadioButton x:Name="rbAngle30" Content="30°"
                         FontSize="12"
                         VerticalAlignment="Center"
                         Checked="RbAngle_Changed"/>
        </StackPanel>

        <!-- ─── Hint ─── -->
        <TextBlock Grid.Row="5"
                   FontSize="11"
                   Foreground="#666666"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Text="Труба A разрезается с двух сторон от пересечения (±полудлина), средний участок опускается вниз на величину отступа, соединения создаются автоматически."/>

        <!-- ─── Action Button ─── -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="btnResolve"
                    Content="Выполнить обход"
                    Style="{StaticResource SecondaryButton}"
                    IsEnabled="False"
                    Click="BtnResolve_Click"/>
        </StackPanel>

        <!-- ─── Status GroupBox ─── -->
        <GroupBox Grid.Row="7"
                  Header="Статус"
                  MinHeight="36"
                  BorderBrush="#D0D0D0"
                  FontSize="12"
                  Margin="0,0,0,8">
            <TextBlock x:Name="txtStatus"
                       Padding="8,4"
                       FontSize="12"
                       Foreground="#495057"
                       TextWrapping="Wrap"
                       Text="Готов к работе"/>
        </GroupBox>

        <!-- ─── Diagnostics GroupBox ─── -->
        <GroupBox x:Name="grpDiagnostics"
                  Grid.Row="8"
                  Header="Диагностика"
                  MinHeight="60"
                  BorderBrush="#D0D0D0"
                  FontSize="12"
                  Visibility="Collapsed">
            <TextBlock x:Name="txtDiagnostics"
                       Padding="8,4"
                       FontSize="11"
                       FontFamily="Consolas"
                       Foreground="#495057"
                       TextWrapping="Wrap"
                       LineHeight="18"/>
        </GroupBox>

    </Grid>
</UserControl>

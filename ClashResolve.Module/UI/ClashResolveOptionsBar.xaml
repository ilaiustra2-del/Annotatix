<UserControl x:Class="ClashResolve.Module.UI.ClashResolveOptionsBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI"
             FontSize="12"
             Background="#4C4C4C"
             VerticalAlignment="Stretch">

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">

        <!-- Title -->
        <TextBlock Text="Исправление коллизий"
                   FontWeight="SemiBold"
                   Foreground="#E8E8E8"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"/>

        <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

        <!-- Angle -->
        <TextBlock Text="Угол обхода:"
                   Foreground="#CCCCCC"
                   VerticalAlignment="Center"
                   Margin="4,0,4,0"/>
        <ComboBox x:Name="cmbAngle"
                  Width="60"
                  VerticalAlignment="Center"
                  Margin="0,0,8,0"
                  SelectionChanged="CmbAngle_SelectionChanged">
            <!-- Full template override — bypasses Revit's system theme entirely -->
            <ComboBox.Template>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Focusable="False" ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="TgBd"
                                            Background="#3C3C3C"
                                            BorderBrush="#555555"
                                            BorderThickness="1"
                                            CornerRadius="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="16"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- selected value text -->
                                            <ContentPresenter Grid.Column="0"
                                                              Margin="4,2,0,2"
                                                              Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                              ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                              TextElement.Foreground="#FFFFFF"
                                                              VerticalAlignment="Center"
                                                              IsHitTestVisible="False"/>
                                            <!-- arrow -->
                                            <Path Grid.Column="1"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                                  Fill="#AAAAAA"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TgBd" Property="Background" Value="#505050"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="TgBd" Property="Background" Value="#505050"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Popup x:Name="Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border x:Name="DropBd"
                                    Background="#3C3C3C"
                                    BorderBrush="#555555"
                                    BorderThickness="1"
                                    MinWidth="{TemplateBinding ActualWidth}">
                                <ScrollViewer>
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </ComboBox.Template>
            <ComboBox.ItemContainerStyle>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bd" Background="#3C3C3C" Padding="6,3">
                                    <TextBlock x:Name="Txt"
                                               Text="{TemplateBinding ContentControl.Content}"
                                               Foreground="#FFFFFF"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#555555"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#4A4A4A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ComboBox.ItemContainerStyle>
            <ComboBoxItem Content="90°" IsSelected="True"/>
            <ComboBoxItem Content="45°"/>
        </ComboBox>

        <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

        <!-- Clearance -->
        <TextBlock Text="Величина опуска:"
                   Foreground="#CCCCCC"
                   VerticalAlignment="Center"
                   Margin="4,0,4,0"/>
        <TextBox x:Name="txtClearance"
                 Width="52"
                 Text="50"
                 Background="#3A3A3A"
                 Foreground="#E8E8E8"
                 BorderBrush="#666666"
                 CaretBrush="#E8E8E8"
                 VerticalAlignment="Center"
                 VerticalContentAlignment="Center"
                 Padding="3,1"
                 Margin="0,0,6,0"
                 IsEnabled="False"
                 Opacity="0.5"/>
        <CheckBox x:Name="chkAutoClearance"
                  Content="Авто"
                  IsChecked="True"
                  Foreground="#E8E8E8"
                  VerticalAlignment="Center"
                  Margin="0,0,8,0"/>

        <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

        <!-- Segment length -->
        <TextBlock Text="Длина сегмента:"
                   Foreground="#CCCCCC"
                   VerticalAlignment="Center"
                   Margin="4,0,4,0"/>
        <TextBox x:Name="txtSegmentLength"
                 Width="52"
                 Text="600"
                 Background="#3A3A3A"
                 Foreground="#E8E8E8"
                 BorderBrush="#666666"
                 CaretBrush="#E8E8E8"
                 VerticalAlignment="Center"
                 VerticalContentAlignment="Center"
                 Padding="3,1"
                 Margin="0,0,6,0"
                 IsEnabled="False"
                 Opacity="0.5"/>
        <CheckBox x:Name="chkAutoLength"
                  Content="Авто"
                  IsChecked="True"
                  Foreground="#E8E8E8"
                  VerticalAlignment="Center"
                  Margin="0,0,8,0"/>

        <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

        <!-- Status hint -->
        <TextBlock x:Name="txtSelectionHint"
                   Text="Выделите трубу A"
                   Foreground="#AAAAAA"
                   FontStyle="Italic"
                   VerticalAlignment="Center"
                   Margin="4,0,8,0"/>

        <!-- Execute -->
        <Button x:Name="btnResolve"
                Content="Перестроить"
                Foreground="#E8E8E8"
                Background="#5A5A5A"
                BorderBrush="#888888"
                Padding="10,2"
                VerticalAlignment="Center"
                Margin="0,0,4,0"
                Click="BtnResolve_Click"/>

        <!-- Exit -->
        <Button x:Name="btnExit"
                Content="Выйти"
                Foreground="#E8E8E8"
                Background="#5A3A3A"
                BorderBrush="#888888"
                Padding="10,2"
                VerticalAlignment="Center"
                Click="BtnExit_Click"/>

    </StackPanel>
</UserControl>

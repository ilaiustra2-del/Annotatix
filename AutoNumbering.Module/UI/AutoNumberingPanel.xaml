<UserControl x:Class="AutoNumbering.Module.UI.AutoNumberingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White"
             FontFamily="Segoe UI">
    
    <UserControl.Resources>
        <ResourceDictionary Source="SharedStyles.xaml"/>
    </UserControl.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Field 1: Active View Name -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Активный вид:" 
                       FontSize="12" 
                       Foreground="#333333"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="txtActiveView"
                     Text="[Не выбран]"
                     IsReadOnly="True"
                     Background="#F8F8F8"
                     BorderBrush="#ADADAD"
                     BorderThickness="1"
                     Padding="6"
                     FontSize="12"
                     Foreground="#333333"/>
        </StackPanel>
        
        <!-- Field 2: Prefix and Postfix -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Prefix field -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Префикс:" 
                           FontSize="12" 
                           Foreground="#333333"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="txtPrefix"
                         Background="White"
                         BorderBrush="#ADADAD"
                         BorderThickness="1"
                         Padding="6"
                         FontSize="12"
                         Foreground="#333333"
                         ToolTip="Например: Т- (результат: Т-1, Т-2, Т-3...)"/>
            </StackPanel>
            
            <!-- Postfix field -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Постфикс:" 
                           FontSize="12" 
                           Foreground="#333333"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="txtPostfix"
                         Background="White"
                         BorderBrush="#ADADAD"
                         BorderThickness="1"
                         Padding="6"
                         FontSize="12"
                         Foreground="#333333"
                         ToolTip="Например: -СТ (результат: 1-СТ, 2-СТ, 3-СТ...)"/>
            </StackPanel>
        </Grid>
        
        <!-- Field 3: Parameter Selection and Grouping Distance -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Parameter Selection -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Параметр для записи номера:" 
                           FontSize="12" 
                           Foreground="#333333"
                           Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbParameter"
                          Background="White"
                          BorderBrush="#ADADAD"
                          BorderThickness="1"
                          Padding="6"
                          FontSize="12"
                          Foreground="#333333"
                          ToolTip="Выберите параметр для записи номеров стояков"/>
            </StackPanel>
            
            <!-- Grouping Distance -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Радиус группировки (мм):" 
                           FontSize="12" 
                           Foreground="#333333"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="txtGroupDistance"
                         Text="400"
                         Background="White"
                         BorderBrush="#ADADAD"
                         BorderThickness="1"
                         Padding="6"
                         FontSize="12"
                         Foreground="#333333"
                         HorizontalContentAlignment="Center"
                         ToolTip="Расстояние для группировки стояков (0 = все отдельно)"/>
            </StackPanel>
        </Grid>
        
        <!-- Field 4: Status Info -->
        <Border Grid.Row="3" 
                Background="#F9F9F9"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Статус:" 
                           FontSize="12" 
                           Foreground="#666666"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <TextBlock x:Name="txtStatus"
                           Text="Нажмите 'Анализировать' для поиска стояков"
                           FontSize="12"
                           Foreground="#333333"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <!-- Spacer -->
        <Grid Grid.Row="4"/>
        
        <!-- Buttons at bottom -->
        <StackPanel Grid.Row="5" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="btnAnalyze"
                    Content="Анализировать"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    Click="BtnAnalyze_Click"/>
            <Button x:Name="btnManageGroups"
                    Content="Управление группами систем"
                    Style="{StaticResource SecondaryButton}"
                    IsEnabled="False"
                    Margin="0,0,8,0"
                    Click="BtnManageGroups_Click"
                    ToolTip="Настройка групп совместимости систем для объединения стояков"/>
            <Button x:Name="btnNumber"
                    Content="Пронумеровать стояки"
                    Style="{StaticResource PrimaryButton}"
                    IsEnabled="False"
                    Click="BtnNumber_Click"/>
        </StackPanel>
    </Grid>
</UserControl>

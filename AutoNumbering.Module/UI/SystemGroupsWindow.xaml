<Window x:Class="AutoNumbering.Module.UI.SystemGroupsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление группами систем"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterScreen"
        Background="White"
        FontFamily="Segoe UI">
    
    <Window.Resources>
        <ResourceDictionary Source="SharedStyles.xaml"/>
    </Window.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Создайте группы совместимости для объединения стояков разных типов систем"
                   FontSize="14"
                   Foreground="#333333"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Panel: Available System Types -->
            <Border Grid.Column="0"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    Background="#F9F9F9">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Available Systems Header -->
                    <Border Grid.Row="0"
                            Background="#F0F0F0"
                            BorderBrush="#E0E0E0"
                            BorderThickness="0,0,0,1"
                            Padding="12">
                        <TextBlock Text="Доступные типы систем"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"/>
                    </Border>
                    
                    <!-- System Types List with Checkboxes -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="12">
                        <ItemsControl x:Name="lstSystemTypes">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding}"
                                              FontSize="12"
                                              Margin="0,4"
                                              Foreground="#333333"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <!-- Create Group Button -->
                    <Button Grid.Row="2"
                            x:Name="btnCreateGroup"
                            Content="Создать группу из выбранных"
                            Style="{StaticResource PrimaryButton}"
                            Margin="12"
                            Click="BtnCreateGroup_Click"/>
                </Grid>
            </Border>
            
            <!-- Right Panel: Created Groups -->
            <Border Grid.Column="2"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    Background="#F9F9F9">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Created Groups Header -->
                    <Border Grid.Row="0"
                            Background="#F0F0F0"
                            BorderBrush="#E0E0E0"
                            BorderThickness="0,0,0,1"
                            Padding="12">
                        <TextBlock Text="Созданные группы совместимости"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"/>
                    </Border>
                    
                    <!-- Groups List -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="12">
                        <StackPanel x:Name="pnlGroups">
                            <!-- Groups will be added dynamically -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Отмена"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    Click="BtnCancel_Click"/>
            <Button Content="Применить"
                    Style="{StaticResource PrimaryButton}"
                    Click="BtnApply_Click"/>
        </StackPanel>
    </Grid>
</Window>

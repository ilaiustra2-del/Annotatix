<UserControl x:Class="Tracer.Module.UI.TracerOptionsBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI"
             FontSize="12"
             Background="#4C4C4C"
             VerticalAlignment="Stretch">

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">

        <!-- Title -->
        <TextBlock x:Name="txtTitle"
                   Text="Tracer"
                   FontWeight="SemiBold"
                   Foreground="#E8E8E8"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"/>

        <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

        <!-- Connection Type -->
        <TextBlock x:Name="txtConnectionType"
                   Text="| Присоединение под 45°"
                   Foreground="#CCCCCC"
                   VerticalAlignment="Center"
                   Margin="4,0,8,0"/>

        <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

        <!-- Stage 1: Select Main -->
        <TextBlock x:Name="txtStage1"
                   Text="Выберите магистральную трубу"
                   Foreground="#AAAAAA"
                   FontStyle="Italic"
                   VerticalAlignment="Center"
                   Margin="4,0,8,0"
                   Visibility="Visible"/>

        <!-- Stage 2: Select Risers -->
        <TextBlock x:Name="txtStage2"
                   Text="Выберите стояки"
                   Foreground="#AAAAAA"
                   FontStyle="Italic"
                   VerticalAlignment="Center"
                   Margin="4,0,4,0"
                   Visibility="Collapsed"/>
        <TextBlock x:Name="txtRiserCount"
                   Text="Выбрано: 0"
                   Foreground="#88CC88"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"
                   Visibility="Collapsed"/>

        <!-- Stage 3: Configure Slope -->
        <StackPanel x:Name="panelStage3" Orientation="Horizontal" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Уклон:"
                           Foreground="#CCCCCC"
                           VerticalAlignment="Center"
                           Margin="4,0,2,0"/>
                <TextBox x:Name="txtSlope"
                         Width="40"
                         Text="2.0"
                         Background="#3A3A3A"
                         Foreground="#E8E8E8"
                         BorderBrush="#666666"
                         CaretBrush="#E8E8E8"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center"
                         Padding="2,1"
                         Margin="0,0,4,0"
                         IsEnabled="False"
                         Opacity="0.5"
                         TextChanged="TxtSlope_TextChanged"/>
                <CheckBox x:Name="chkUseMainLineSlope"
                          Content="Как у магистрали"
                          IsChecked="True"
                          Foreground="#E8E8E8"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          Checked="ChkUseMainLineSlope_Changed"
                          Unchecked="ChkUseMainLineSlope_Changed"/>
            </StackPanel>
            
            <CheckBox x:Name="chkAddFittings"
                      Content="Добавить фитинги"
                      IsChecked="True"
                      Foreground="#E8E8E8"
                      VerticalAlignment="Center"
                      Margin="4,0,4,0"
                      ToolTip="Добавлять соединительные детали (отводы) между сегментами труб"/>
        </StackPanel>

        <Rectangle Width="1" Fill="#666666" Margin="4,3"/>

        <!-- Done Button -->
        <Button x:Name="btnDone"
                Content="Готово"
                Foreground="#E8E8E8"
                Background="#5A5A5A"
                BorderBrush="#888888"
                Padding="10,2"
                VerticalAlignment="Center"
                Margin="0,0,4,0"
                Click="BtnDone_Click"
                IsEnabled="False"/>

        <!-- Cancel Button -->
        <Button x:Name="btnCancel"
                Content="Отмена"
                Foreground="#E8E8E8"
                Background="#5A3A3A"
                BorderBrush="#888888"
                Padding="10,2"
                VerticalAlignment="Center"
                Click="BtnCancel_Click"/>

    </StackPanel>
</UserControl>

<UserControl x:Class="Tracer.Module.UI.TracerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White"
             FontFamily="Segoe UI">
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Section Title -->
        <TextBlock Grid.Row="0"
                   Text="Трассировка канализации"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#333333"
                   Margin="0,0,0,4"/>
        
        <TextBlock Grid.Row="1"
                   Text="Присоединение стояков к магистральным линиям"
                   FontSize="12"
                   Foreground="#666666"
                   Margin="0,0,0,12"/>
        
        <!-- 1. Main Line Selection -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="1. Выбор магистральной линии" 
                       FontSize="12" 
                       Foreground="#333333"
                       Margin="0,0,0,4"/>
            <Button x:Name="SelectMainLineButton"
                    Content="Выбрать магистральную линию"
                    Background="#0078D4"
                    Foreground="White"
                    Padding="16,8"
                    BorderThickness="0"
                    Click="SelectMainLineButton_Click"/>
            <Border BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    Background="#F8F8F8"
                    Padding="8"
                    Margin="0,4,0,0">
                <StackPanel>
                    <TextBlock x:Name="MainLineStatusText"
                               Text="Магистраль: не выбрана"
                               FontSize="12"
                               Foreground="#333333"/>
                    <TextBlock x:Name="MainLineDetailsText"
                               Text=""
                               FontSize="11"
                               Foreground="#666666"/>
                </StackPanel>
            </Border>
        </StackPanel>
        
        <!-- 2. Riser Selection -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="2. Выбор стояка" 
                       FontSize="12" 
                       Foreground="#333333"
                       Margin="0,0,0,4"/>
            <Button x:Name="SelectRiserButton"
                    Content="Выбрать стояк"
                    Background="#F3F3F3"
                    Foreground="#333333"
                    Padding="16,8"
                    BorderBrush="#ADADAD"
                    BorderThickness="1"
                    Click="SelectRiserButton_Click"
                    IsEnabled="False"/>
            <Border BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    Background="#F8F8F8"
                    Padding="8"
                    Margin="0,4,0,0">
                <StackPanel>
                    <TextBlock x:Name="RiserStatusText"
                               Text="Стояк: не выбран"
                               FontSize="12"
                               Foreground="#333333"/>
                    <TextBlock x:Name="RiserDetailsText"
                               Text=""
                               FontSize="11"
                               Foreground="#666666"/>
                    
                    <!-- Connection Info -->
                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <TextBlock Text="Высота подключения (мм):" 
                                   FontSize="11"
                                   Foreground="#666666"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="ConnectionHeightTextBlock"
                                   Width="60"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="#333333"
                                   Text="-"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                        <TextBlock Text="Диаметр трубы (мм):" 
                                   FontSize="11"
                                   Foreground="#666666"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="PipeDiameterTextBlock"
                                   Width="60"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="#333333"
                                   Text="-"/>
                    </StackPanel>
                    
                    <!-- Slope Settings -->
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="Настройки уклона:" 
                                   FontSize="11"
                                   Foreground="#666666"/>
                        
                        <CheckBox x:Name="UseMainLineSlopeCheckBox"
                                  Content="Использовать значение уклона магистрали"
                                  IsChecked="True"
                                  FontSize="11"
                                  Foreground="#333333"
                                  Margin="0,4,0,4"
                                  Checked="UseMainLineSlopeCheckBox_CheckedChanged"
                                  Unchecked="UseMainLineSlopeCheckBox_CheckedChanged"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                            <TextBlock Text="Уклон трубы (%):" 
                                       FontSize="11"
                                       Foreground="#666666"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="PipeSlopeTextBox"
                                     Width="60"
                                     Height="22"
                                     Margin="8,0,0,0"
                                     VerticalAlignment="Center"
                                     FontSize="11"
                                     Padding="4,2"
                                     BorderBrush="#ADADAD"
                                     IsEnabled="False"
                                     Text="2.0"/>
                        </StackPanel>
                        
                        <!-- Add Fittings Checkbox -->
                        <CheckBox x:Name="AddFittingsCheckBox"
                                  Content="Добавить фитинги"
                                  IsChecked="True"
                                  FontSize="11"
                                  Foreground="#333333"
                                  Margin="0,8,0,0"
                                  ToolTip="Автоматически создавать соединительные детали (отводы) между сегментами труб и стояком"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
        
        <!-- Connection Type Icons -->
        <UniformGrid Grid.Row="4" Columns="4" Margin="0,0,0,12">
            <Button x:Name="CreateConnectionButton"
                    Background="Transparent" BorderThickness="0" Padding="4"
                    Click="CreateConnectionButton_Click"
                    IsEnabled="False"
                    Margin="4,0"
                    ToolTip="Присоединение под 45°">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Border x:Name="IconBorder45" 
                            BorderBrush="#ADADAD" 
                            BorderThickness="1" 
                            Width="100" 
                            Height="100" 
                            Background="White">
                        <Grid>
                            <Image Source="icons/Tracer_icons/Tracer_45.png" Width="90" Height="90"/>
                            <Border x:Name="Overlay45" Background="#80000000" Opacity="0"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="45°" FontSize="12" Foreground="#333333" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
            
            <Button x:Name="CreateLConnectionButton"
                    Background="Transparent" BorderThickness="0" Padding="4"
                    Click="CreateLConnectionButton_Click"
                    IsEnabled="False"
                    Margin="4,0"
                    ToolTip="L-образное присоединение">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Border x:Name="IconBorderL" 
                            BorderBrush="#ADADAD" 
                            BorderThickness="1" 
                            Width="100" 
                            Height="100" 
                            Background="White">
                        <Grid>
                            <Image Source="icons/Tracer_icons/Tracer_L.png" Width="90" Height="90"/>
                            <Border x:Name="OverlayL" Background="#80000000" Opacity="0"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="L-образное" FontSize="12" Foreground="#333333" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
            
            <Button x:Name="CreateBottomConnectionButton"
                    Background="Transparent" BorderThickness="0" Padding="4"
                    Click="CreateBottomConnectionButton_Click"
                    IsEnabled="False"
                    Margin="4,0"
                    ToolTip="Присоединение снизу (перпендикулярно)">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Border x:Name="IconBorderBottom" 
                            BorderBrush="#ADADAD" 
                            BorderThickness="1" 
                            Width="100" 
                            Height="100" 
                            Background="White">
                        <Grid>
                            <Image Source="icons/Tracer_icons/Tracer_Bottom.png" Width="90" Height="90"/>
                            <Border x:Name="OverlayBottom" Background="#80000000" Opacity="0"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="Снизу" FontSize="12" Foreground="#333333" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
            
            <Button x:Name="CreateZConnectionButton"
                    Background="Transparent" BorderThickness="0" Padding="4"
                    Click="CreateZConnectionButton_Click"
                    IsEnabled="False"
                    Margin="4,0"
                    ToolTip="Z-образное присоединение">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Border x:Name="IconBorderZ" 
                            BorderBrush="#ADADAD" 
                            BorderThickness="1" 
                            Width="100" 
                            Height="100" 
                            Background="White">
                        <Grid>
                            <Image Source="icons/Tracer_icons/Tracer_Z.png" Width="90" Height="90"/>
                            <Border x:Name="OverlayZ" Background="#80000000" Opacity="0"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="Z-образное" FontSize="12" Foreground="#333333" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
        </UniformGrid>
        
        <!-- Status Box -->
        <GroupBox Grid.Row="5"
                  Header="Статус"
                  MinHeight="60"
                  BorderBrush="#D0D0D0"
                  FontSize="12"
                  Margin="0,0,0,8">
            <Grid>
                <TextBlock x:Name="txtStatus"
                           Padding="8"
                           FontSize="12"
                           Foreground="#495057"
                           TextWrapping="Wrap"
                           Text="Готов к работе. Выберите магистральную линию."/>
            </Grid>
        </GroupBox>
        
    </Grid>
</UserControl>

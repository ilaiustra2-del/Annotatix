<UserControl x:Class="Annotatix.Module.UI.AnnotatixPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Description -->
        <TextBlock Grid.Row="0"
                   Text="Annotatix — автоматизация расстановки аннотаций и растровый анализ вида"
                   FontSize="12"
                   Foreground="#666666"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <!-- Parameters section -->
        <GroupBox Grid.Row="1"
                  Header="Параметры расчёта"
                  BorderBrush="#D0D0D0"
                  FontSize="12"
                  Margin="0,0,0,12">
            <Grid Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Grid Step -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                    <TextBlock Text="Шаг сетки (мм):"
                               FontSize="12"
                               Foreground="#333333"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbGridStep"
                              Height="26"
                              FontSize="12"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              BorderBrush="#ADADAD"
                              Background="White"
                              Text="3"
                              LostFocus="CmbGridStep_LostFocus"
                              SelectionChanged="CmbGridStep_SelectionChanged"/>
                </StackPanel>

                <!-- Occupancy Threshold -->
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                    <TextBlock Text="Порог занятости (%):"
                               FontSize="12"
                               Foreground="#333333"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbOccupancyThreshold"
                              Height="26"
                              FontSize="12"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              BorderBrush="#ADADAD"
                              Background="White"
                              Text="10"
                              LostFocus="CmbOccupancyThreshold_LostFocus"
                              SelectionChanged="CmbOccupancyThreshold_SelectionChanged"/>
                </StackPanel>

                <!-- Edge Margin -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,0">
                    <TextBlock Text="Отступ от краев объектов (мм):"
                               FontSize="12"
                               Foreground="#333333"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbEdgeMargin"
                              Height="26"
                              FontSize="12"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              BorderBrush="#ADADAD"
                              Background="White"
                              Text="0"
                              LostFocus="CmbEdgeMargin_LostFocus"
                              SelectionChanged="CmbEdgeMargin_SelectionChanged"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="btnRasterExport"
                    Content="Растр. экспорт"
                    Style="{StaticResource PrimaryButton}"
                    Click="BtnRasterExport_Click"
                    Margin="0,0,12,0"/>
            <Button x:Name="btnAnnotateDuctwork"
                    Content="Авто-разметка воздуховодов"
                    Style="{StaticResource SecondaryButton}"
                    Click="BtnAnnotateDuctwork_Click"/>
        </StackPanel>

        <!-- Status Box -->
        <GroupBox Grid.Row="5"
                  Header="Статус"
                  MinHeight="60"
                  BorderBrush="#D0D0D0"
                  FontSize="12">
            <Grid>
                <TextBlock x:Name="txtProgress"
                           Padding="8"
                           FontSize="12"
                           Foreground="#333333"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="txtStatus"
                           Padding="8"
                           FontSize="12"
                           Foreground="#495057"
                           TextWrapping="Wrap"
                           Text="Панель готова к работе. Измените параметры и нажмите кнопку действия."/>
            </Grid>
        </GroupBox>

        <!-- Footer: current settings info -->
        <TextBlock Grid.Row="6"
                   Text="Настройки сохраняются автоматически в JSON-файл рядом с модулем."
                   FontSize="11"
                   Foreground="#999999"
                   TextAlignment="Center"
                   Margin="0,12,0,0"/>
    </Grid>
</UserControl>

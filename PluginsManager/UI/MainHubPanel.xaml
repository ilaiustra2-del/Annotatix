<Window x:Class="PluginsManager.UI.MainHubPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="MainWindow"
        Title="Менеджер плагинов AnnotatiX.AI"
        Width="767"
        Height="584"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="White"
        FontFamily="Segoe UI"
        BorderBrush="#7A7A7A"
        BorderThickness="1">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Plugin Card Style -->
            <Style x:Key="PluginCard" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#D0D0D0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="2"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Margin" Value="0,0,12,12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Height" Value="130"/>
                <Setter Property="Width" Value="120"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#E5F3FF"/>
                        <Setter Property="BorderBrush" Value="#0078D4"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            
            <Style x:Key="PluginCardDisabled" TargetType="Border" BasedOn="{StaticResource PluginCard}">
                <Setter Property="Opacity" Value="0.5"/>
                <Setter Property="Cursor" Value="Arrow"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Title Bar (hidden by default, visible only when showing module panels) -->
        <Border x:Name="TitleBar"
                Grid.Row="0" 
                Background="White" 
                BorderBrush="#D0D0D0" 
                BorderThickness="0,0,0,1"
                Padding="16,8"
                Visibility="Collapsed">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnBack"
                            Content="← Назад"
                            Style="{StaticResource BackButton}"
                            Click="BtnBack_Click"
                            Margin="0,0,16,0"/>
                    <TextBlock x:Name="txtModuleTitle"
                               Text="" 
                               Style="{StaticResource WindowTitle}"/>
                </StackPanel>
                <!-- Close button removed - use Windows close button instead -->
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid x:Name="MainContentGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="SidebarColumn" Width="280"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left: Plugin Grid -->
            <Grid x:Name="ContentArea" Grid.Column="0" Background="#F5F5F5">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <ContentControl x:Name="MainContent">
                            <StackPanel>
                                <TextBlock Text="Доступные плагины" 
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="Black"
                                           Margin="0,0,0,16"/>
                                
                                <!-- Plugin Grid 3x3 -->
                                <WrapPanel>
                                    <!-- DWG2RVT Plugin -->
                                    <Border x:Name="pnlDwg2rvt"
                                            Style="{StaticResource PluginCardDisabled}"
                                            MouseLeftButtonUp="Dwg2rvt_Click">
                                        <StackPanel>
                                            <Image x:Name="imgDwg2rvtIcon"
                                                   Width="64"
                                                   Height="64"
                                                   Margin="0,0,0,8"
                                                   Stretch="Uniform"/>
                                            <TextBlock Text="DWG2RVT"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Foreground="#333333"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- HVAC Plugin -->
                                    <Border x:Name="pnlHvac"
                                            Style="{StaticResource PluginCardDisabled}"
                                            MouseLeftButtonUp="Hvac_Click">
                                        <StackPanel>
                                            <Image x:Name="imgHvacIcon"
                                                   Width="64"
                                                   Height="64"
                                                   Margin="0,0,0,8"
                                                   Stretch="Uniform"/>
                                            <TextBlock Text="HVAC"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Foreground="#333333"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- FamilySync Plugin -->
                                    <Border x:Name="pnlFamilySync"
                                            Style="{StaticResource PluginCardDisabled}"
                                            MouseLeftButtonUp="FamilySync_Click">
                                        <StackPanel>
                                            <Image x:Name="imgFamilySyncIcon"
                                                   Width="64"
                                                   Height="64"
                                                   Margin="0,0,0,8"
                                                   Stretch="Uniform"/>
                                            <TextBlock Text="Family Sync"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Foreground="#333333"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- AutoNumbering Plugin -->
                                    <Border x:Name="pnlAutoNumbering"
                                            Style="{StaticResource PluginCardDisabled}"
                                            MouseLeftButtonUp="AutoNumbering_Click">
                                        <StackPanel>
                                            <Image x:Name="imgAutoNumberingIcon"
                                                   Width="64"
                                                   Height="64"
                                                   Margin="0,0,0,8"
                                                   Stretch="Uniform"/>
                                            <TextBlock Text="AutoNumbering"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Foreground="#333333"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- ClashResolve Plugin -->
                                    <Border x:Name="pnlClashResolve"
                                            Style="{StaticResource PluginCardDisabled}"
                                            MouseLeftButtonUp="ClashResolve_Click">
                                        <StackPanel>
                                            <Image x:Name="imgClashResolveIcon"
                                                   Width="64"
                                                   Height="64"
                                                   Margin="0,0,0,8"
                                                   Stretch="Uniform"/>
                                            <TextBlock Text="Clash Resolve"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Foreground="#333333"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Placeholder 1-4 -->
                                    <Border Style="{StaticResource PluginCardDisabled}"/>
                                    <Border Style="{StaticResource PluginCardDisabled}"/>
                                    <Border Style="{StaticResource PluginCardDisabled}"/>
                                    <Border Style="{StaticResource PluginCardDisabled}"/>
                                </WrapPanel>
                            </StackPanel>
                        </ContentControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
            
            <!-- Right Sidebar -->
            <Grid x:Name="RightSidebar" Grid.Column="1" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Account Section -->
                <Border Grid.Row="0"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1,0,0,1"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Учётная запись" 
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="Black"
                                   Margin="0,0,0,12"/>
                        
                        <!-- Auth Status Container -->
                        <StackPanel x:Name="pnlAuthStatus">
                            <!-- Warning Message (shown when not authenticated) -->
                            <Border x:Name="warningMessage"
                                    Style="{StaticResource WarningMessage}"
                                    Margin="0,0,0,8">
                                <TextBlock Text="⚠ Требуется авторизация"
                                           FontSize="12"
                                           Foreground="#856404"/>
                            </Border>
                            
                            <!-- Success Message (shown when authenticated) -->
                            <Border x:Name="successMessage"
                                    Style="{StaticResource SuccessMessage}"
                                    Margin="0,0,0,8"
                                    Visibility="Collapsed">
                                <TextBlock Text="✓ Вы авторизованы"
                                           FontSize="12"
                                           Foreground="#2D662D"/>
                            </Border>
                            
                            <!-- License Info (shown when authenticated) -->
                            <StackPanel x:Name="pnlLicenseInfo"
                                        Visibility="Collapsed"
                                        Margin="0,0,0,8">
                                <TextBlock FontSize="12" Foreground="#666666">
                                    <Run Text="Лицензия: "/>
                                    <Run x:Name="txtPlan" Text="Pro Plan" FontWeight="SemiBold"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="#666666" Margin="0,4,0,0">
                                    <Run Text="До: "/>
                                    <Run x:Name="txtExpiry" Text="15.03.2026" FontWeight="SemiBold"/>
                                </TextBlock>
                            </StackPanel>
                            
                            <!-- Auth Button -->
                            <Button x:Name="btnAuth"
                                    Content="Войти"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnAuth_Click"
                                    Margin="0,8,0,0"/>
                            
                            <!-- Refresh Button (hidden by default) -->
                            <Button x:Name="btnRefreshUserData"
                                    Content="Обновить данные"
                                    Style="{StaticResource SecondaryButton}"
                                    Visibility="Collapsed"
                                    Click="BtnRefreshUserData_Click"
                                    Margin="0,8,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- News Section -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              BorderBrush="#D0D0D0"
                              BorderThickness="1,0,0,1">
                    <StackPanel Margin="16">
                        <TextBlock Text="Новости" 
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="Black"
                                   Margin="0,0,0,12"/>
                        
                        <!-- News Item 1 -->
                        <Border Background="#F9F9F9"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="12.02.2026"
                                           FontSize="10"
                                           Foreground="#999999"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Обновление v2.0"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#333333"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Добавлена поддержка Revit 2025. Улучшена производительность модуля HVAC."
                                           FontSize="11"
                                           Foreground="#666666"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- News Item 2 -->
                        <Border Background="#F9F9F9"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="05.02.2026"
                                           FontSize="10"
                                           Foreground="#999999"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Новый плагин"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#333333"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Скоро выйдет модуль Electra для работы с электросхемами."
                                           FontSize="11"
                                           Foreground="#666666"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Debug Section -->
                <Border Grid.Row="2"
                        Background="#F5F5F5"
                        Padding="16"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1,0,0,0">
                    <StackPanel>
                    <Button Content="📋 Debug Log"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,0,8"
                            Click="BtnDebugLog_Click"/>
                    <Button Content="📦 Инфо о модулях"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnModulesInfo_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="#F0F0F0"
                BorderBrush="#D0D0D0"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <TextBlock x:Name="txtStatusLeft"
                           Text="Готов к работе"
                           FontSize="12"
                           Foreground="#666666"
                           HorizontalAlignment="Left"/>
                <TextBlock x:Name="txtStatusRight"
                           Text="Revit 2024 | Build 23.1.12"
                           FontSize="12"
                           Foreground="#666666"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
